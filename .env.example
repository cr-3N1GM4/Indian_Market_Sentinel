# ==============================================================
# Indian Market Sentinel (IMS) — Environment Configuration
# Copy this file to .env and fill in your credentials
# ==============================================================

# --- LLM (Primary: Anthropic Claude) ---
ANTHROPIC_API_KEY=sk-ant-...          # Get from console.anthropic.com
# OPENAI_API_KEY=sk-...              # Optional fallback — from platform.openai.com

# --- Social / Community APIs ---
# TWITTER_BEARER_TOKEN=AAAA...         # From developer.twitter.com → Project → App → Bearer Token
# REDDIT_CLIENT_ID=abc123              # From reddit.com/prefs/apps → "create another app" → client_id
# REDDIT_CLIENT_SECRET=xyz789          # Same page → secret
# REDDIT_USER_AGENT=IMS/1.0 by u/yourusername

# --- Macro Data ---
FRED_API_KEY=aaa....  # From fred.stlouisfed.org/docs/api/api_key.html

# --- Database ---
DATABASE_URL=postgresql://ims:your_strong_password_here@postgres:5432/ims_db
POSTGRES_PASSWORD=your_strong_password_here
REDIS_URL=redis://redis:6379

# --- Optional ---
PROXY_LIST=                          # Comma-separated: http://proxy1:port,http://proxy2:port
